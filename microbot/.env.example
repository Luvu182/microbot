# ========================================
# microbot - Environment Configuration
# ========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ========================================
# LLM Providers (at least one required)
# ========================================
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=
# OPENROUTER_API_KEY=
# GEMINI_API_KEY=

# ========================================
# Chat Channels (enable what you need)
# ========================================

# Telegram
# TELEGRAM_BOT_TOKEN=

# Discord
# DISCORD_BOT_TOKEN=

# Slack
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# WhatsApp (requires Node.js bridge)
# WHATSAPP_BRIDGE_TOKEN=

# ========================================
# Agent Settings
# ========================================
# MICROBOT_MODEL=anthropic/claude-sonnet-4-20250514
# MICROBOT_WORKSPACE=~/.microbot/workspace
