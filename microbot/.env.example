# ========================================
# microbot - Environment Configuration
# ========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ========================================
# LLM Providers (at least one required)
# ========================================
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=
# OPENROUTER_API_KEY=
# GEMINI_API_KEY=

# ========================================
# Chat Channels (enable what you need)
# ========================================

# Telegram
# TELEGRAM_BOT_TOKEN=

# Discord
# DISCORD_BOT_TOKEN=

# Slack
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# Feishu / Lark
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=

# DingTalk
# DINGTALK_CLIENT_ID=
# DINGTALK_CLIENT_SECRET=

# WhatsApp (requires Node.js bridge)
# WHATSAPP_BRIDGE_TOKEN=

# Email
# EMAIL_IMAP_SERVER=
# EMAIL_SMTP_SERVER=
# EMAIL_ADDRESS=
# EMAIL_PASSWORD=

# QQ
# QQ_APP_ID=
# QQ_APP_SECRET=

# Matrix
# MATRIX_HOMESERVER=https://matrix.org
# MATRIX_ACCESS_TOKEN=
# MATRIX_USER_ID=

# ========================================
# Agent Settings
# ========================================
# MICROBOT_MODEL=anthropic/claude-sonnet-4-20250514
# MICROBOT_WORKSPACE=~/.microbot/workspace
